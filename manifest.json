{
  "manifest_version": 3,
  "name": "Featherwise — save to Readwise",
  "version": "1.0.0",
  "description": "Save pages to Readwise Reader and text selections as highlights — built to request the minimum Chrome permissions possible.",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "optional_permissions": ["scripting"],
  "host_permissions": ["https://readwise.io/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Save to Readwise"
  },
  "options_page": "options/options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open the Readwise Saver popup"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
